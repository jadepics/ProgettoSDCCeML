<+>import threading\r\n\r\n\r\nclass WorkerState:\r\n    def __init__(self) -> None:\r\n        self.running_tasks = 0\r\n        self._lock = threading.Lock()\r\n\r\n    def inc(self) -> None:\r\n        with self._lock:\r\n            self.running_tasks += 1\r\n\r\n    def dec(self) -> None:\r\n        with self._lock:\r\n            self.running_tasks = max(0, self.running_tasks - 1)\r\n\r\n    def get(self) -> int:\r\n        with self._lock:\r\n            return self.running_tasks
