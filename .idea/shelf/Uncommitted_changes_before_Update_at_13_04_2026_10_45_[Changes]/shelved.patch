32 n_estimators = 9;\r\n  int32 max_depth = 10;\r\n  string max_features = 11;\r\n  int32 min_samples_split = 12;\r\n  int32 min_samples_leaf = 13;\r\n  string criterion = 14;\r\n  bool bootstrap = 15;\r\n  int32 global_random_seed = 16;\r\n\r\n  string train_features_uri = 17;\r\n  string train_labels_uri = 18;\r\n  string artifact_output_dir = 19;\r\n  int32 seed_base = 20;\r\n  int64 lease_expires_at_unix_ms = 21;\r\n}\r\n\r\nmessage TrainShardResponse {\r\n  string task_id = 1;\r\n  int32 attempt_id = 2;\r\n  string worker_id = 3;\r\n  bool success = 4;\r\n  string error = 5;\r\n  repeated TrainedTreeArtifact artifacts = 6;\r\n  repeated string completed_tree_ids = 7;\r\n  repeated string failed_tree_ids = 8;\r\n  double elapsed_time_seconds = 9;\r\n}\r\n\r\nmessage PredictShardRequest {\r\n  string model_id = 1;\r\n  string experiment_id = 2;\r\n  string task_type = 3;\r\n  DenseMatrix features = 4;\r\n  repeated string tree_artifact_uris = 5;\r\n  repeated string class_labels = 6;\r\n}\r\n\r\nmessage PredictShardResponse {\r\n  string worker_id = 1;\r\n  bool success = 2;\r\n  string error = 3;\r\n  repeated double values = 4;\r\n  int32 n_rows = 5;\r\n  int32 n_cols = 6;\r\n}\r\n\r\nservice CoordinatorService {\r\n  rpc RegisterWorker(RegisterWorkerRequest) returns (RegisterWorkerResponse);\r\n  rpc Heartbeat(HeartbeatRequest) returns (HeartbeatResponse);\r\n  rpc SubmitTraining(SubmitTrainingRequest) returns (SubmitTrainingResponse);\r\n}\r\n\r\nservice WorkerService {\r\n  rpc TrainShard(TrainShardRequest) returns (TrainShardResponse);\r\n  rpc PredictShard(PredictShardRequest) returns (PredictShardResponse);\r\n}\r\n
