+    def _resolve_uri(self, uri: str) -> str:
+        parsed = urlparse(uri)
+
+        # path normale locale
+        if parsed.scheme == "":
+            return uri
+
+        # supportiamo solo file://
+        if parsed.scheme != "file":
+            raise ValueError(
+                f"Unsupported URI scheme '{parsed.scheme}' for '{uri}'"
+            )
+
+        path = url2pathname(unquote(parsed.path))
+
+        # Windows fix
+        if os.name == "nt":
+
+            # file:///C:/...
+            if path.startswith("/") and len(path) > 2 and path[2] == ":":
+                path = path[1:]
+
+            path = os.path.normpath(path)
 
-        return Path(uri)
