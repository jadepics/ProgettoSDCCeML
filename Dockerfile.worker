FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# genera protobuf
RUN python -m grpc_tools.protoc \
    -I. \
    --python_out=. \
    --grpc_python_out=. \
    proto/rf_v2.proto
# storage condiviso
RUN mkdir -p /mnt/efs/gp_artifacts

EXPOSE 50052

CMD ["python", "run_worker.py"]